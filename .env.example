# =============================================================================
# 使用方式：复制为 frontend 目录下的 .env 或 .env.production（仅 VITE_ 会打进前端包）
# =============================================================================

# 前端页面与 API 不同源时填写后端根地址，不要末尾斜杠。例：https://api.你的域名.com
# 本地开发若用 Vite 代理 /api，可不填
VITE_BACKEND_URL=

# 可选兜底：与后端 DINGTALK_CORP_ID 相同（建议优先在后端 .env 配置 DINGTALK_CORP_ID）
VITE_DINGTALK_CORP_ID=

# 可选：与后端 DINGTALK_APP_KEY 相同，供 JSAPI requestAuthCode 的 clientId
VITE_DINGTALK_APP_KEY=
